{
    "name": "hive-builder template container",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        },
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "installOhMyZsh": false,
            "upgradePackages": true,
            "username": "vscode",
            "userUid": "automatic",
            "userGid": "automatic"
        }
    },
    "remoteEnv": {
        "ANSIBLE_CONFIG": "/var/tmp/hive/ansible.cfg",
        "PATH": "${containerWorkspaceFolder}/.venv/bin:${containerEnv:PATH}"
    },
    "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.ansible",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "ansible.playbook.arguments": "-e @/var/tmp/hive/vars.yml",
                "ansible.validation.lint.arguments": "-c .vscode/configs/ansible-lint.yml"
            }
        }
    }
}
